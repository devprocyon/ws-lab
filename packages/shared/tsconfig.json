{
  "compilerOptions": {
    "types": ["node"],
    "module": "commonjs",
    "target": "ES2023",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": "./",
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": true,
    "composite": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}